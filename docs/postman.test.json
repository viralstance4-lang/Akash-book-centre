{
  "info": {
    "name": "Bookstore API — Full Test Suite",
    "_postman_id": "bookstore-full-test-suite",
    "description": "Full test suite for the Bookstore E-Commerce API. Run requests in order.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000/api/v1" },
    { "key": "adminEmail", "value": "aditya@admin.com" },
    { "key": "userEmail", "value": "aditya@user.com" },
    { "key": "password", "value": "password123" },
    { "key": "adminToken", "value": "" },
    { "key": "userToken", "value": "" },
    { "key": "genreId", "value": "" },
    { "key": "bookId", "value": "" },
    { "key": "orderId", "value": "" },
    { "key": "razorpayOrderId", "value": "" },
    { "key": "userId", "value": "" }
  ],
  "item": [
    {
      "name": "1. Auth",
      "item": [
        {
          "name": "1.1 Login Admin",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{adminEmail}}\",\n  \"password\": \"{{password}}\"\n}"
            },
            "url": "{{baseUrl}}/auth/login"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "pm.test('Admin login successful', () => pm.response.to.have.status(200));",
                  "if (json?.data?.accessToken) {",
                  "  pm.collectionVariables.set('adminToken', json.data.accessToken);",
                  "  console.log('Admin token saved');",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "1.2 Login User",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{userEmail}}\",\n  \"password\": \"{{password}}\"\n}"
            },
            "url": "{{baseUrl}}/auth/login"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "pm.test('User login successful', () => pm.response.to.have.status(200));",
                  "if (json?.data?.accessToken) {",
                  "  pm.collectionVariables.set('userToken', json.data.accessToken);",
                  "  console.log('User token saved');",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "1.3 Get Me (User)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{userToken}}" }
            ],
            "url": "{{baseUrl}}/auth/me"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "pm.test('Get me successful', () => pm.response.to.have.status(200));",
                  "if (json?.data?.id) {",
                  "  pm.collectionVariables.set('userId', json.data.id);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "1.4 Refresh Token",
          "request": {
            "method": "POST",
            "header": [],
            "url": "{{baseUrl}}/auth/refresh"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "pm.test('Refresh token successful', () => pm.response.to.have.status(200));",
                  "if (json?.data?.accessToken) {",
                  "  pm.collectionVariables.set('userToken', json.data.accessToken);",
                  "  console.log('User token refreshed');",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "1.5 Validation Error (missing fields)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{}" },
            "url": "{{baseUrl}}/auth/login"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Validation error returns 400', () => pm.response.to.have.status(400));"
                ]
              }
            }
          ]
        },
        {
          "name": "1.6 Wrong Password",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{userEmail}}\",\n  \"password\": \"wrongpassword\"\n}"
