    {
      "name": "3. Books",
      "item": [
        {
          "name": "3.1 Create Book (Admin)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "title", "value": "Dune", "type": "text" },
                { "key": "author", "value": "Frank Herbert", "type": "text" },
                { "key": "isbn", "value": "9780441013593", "type": "text" },
                {
                  "key": "description",
                  "value": "A science fiction epic set in a distant future.",
                  "type": "text"
                },
                { "key": "price", "value": "499", "type": "text" },
                { "key": "genreId", "value": "{{genreId}}", "type": "text" },
                { "key": "stock", "value": "100", "type": "text" },
                { "key": "coverImage", "type": "file", "src": [] }
              ]
            },
            "url": "{{baseUrl}}/books"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "pm.test('Book created', () => pm.response.to.have.status(201));",
                  "if (json?.data?.id) {",
                  "  pm.collectionVariables.set('bookId', json.data.id);",
                  "  console.log('Book ID saved:', json.data.id);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "3.2 List Books (Public)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/books",
              "host": ["{{baseUrl}}"],
              "path": ["books"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('List books successful', () => pm.response.to.have.status(200));"
                ]
              }
            }
          ]
        },
        {
          "name": "3.3 List Books with Search",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/books?q=dune",
              "host": ["{{baseUrl}}"],
              "path": ["books"],
              "query": [{ "key": "q", "value": "dune" }]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Search books successful', () => pm.response.to.have.status(200));"
                ]
              }
            }
          ]
        },
        {
          "name": "3.4 List Books with Price Filter",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/books?minPrice=100&maxPrice=1000",
              "host": ["{{baseUrl}}"],
              "path": ["books"],
              "query": [
                { "key": "minPrice", "value": "100" },
                { "key": "maxPrice", "value": "1000" }
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Price filter successful', () => pm.response.to.have.status(200));"
                ]
              }
            }
          ]
        },
        {
          "name": "3.5 Get Single Book",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/books/{{bookId}}"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Get book successful', () => pm.response.to.have.status(200));"
                ]
              }
            }
          ]
        },
        {
          "name": "3.6 Update Book Stock (Admin)",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"quantity\": 50,\n  \"type\": \"delta\"\n}"
            },
            "url": "{{baseUrl}}/books/{{bookId}}/stock"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Stock updated', () => pm.response.to.have.status(200));"
                ]
              }
            }
          ]
        },
        {
          "name": "3.7 Get Non-existent Book (should fail)",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/books/00000000-0000-0000-0000-000000000000"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Non-existent book returns 404', () => pm.response.to.have.status(404));"
                ]
              }
            }
          ]
        }
      ]
